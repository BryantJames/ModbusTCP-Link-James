# 服务端口号
PORT=3001

# JWT 密钥（生产环境请使用随机生成的长字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# MySQL 数据库配置
# 注意：如果密码包含 # 等特殊字符，请用双引号包裹，例如 DB_PASSWORD="James520!@#"
DB_HOST=120.79.56.98
DB_PORT=3306
DB_USER=james
DB_PASSWORD="your-password"
DB_NAME=modbus_tcp_controller

# 前端跨域来源（开发环境）
CORS_ORIGIN=http://localhost:5173
